# PayHero API Credentials
# Get these from https://app.payhero.co.ke → API Keys
PAYHERO_API_USERNAME=your_api_username
PAYHERO_API_PASSWORD=your_api_password

# PayHero Channel ID
# Get this from https://app.payhero.co.ke → Payment Channels
PAYHERO_CHANNEL_ID=your_channel_id

# Callback URL for PayHero webhooks (must be publicly accessible)
# For local dev, use ngrok: https://ngrok.com
CALLBACK_URL=https://your-domain.com/api/payment/callback

# Server Port
PORT=3000
